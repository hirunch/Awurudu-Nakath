<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    tools:context=".MainActivity2">


    <TextView
        android:id="@+id/headTxt"
        android:layout_width="300dp"
        android:layout_height="60dp"
        android:fontFamily="@font/nirmalaui"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/border"
        android:gravity="center"
        android:text="අවුරුදු නැකැත් 2026"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="27sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.058"
        tools:ignore="MissingConstraints" />

    <ImageButton
        android:id="@+id/soundToggleBtn"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/sound_toggle_desc"
        android:padding="8dp"
        android:src="@android:drawable/ic_lock_silent_mode_off"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/scrollView2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="180dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:layout_gravity="center_horizontal"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/frameOne"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:background="@drawable/list_border"
                android:padding="30dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/nbox"
                        android:padding="10dp"
                        android:text="අවුරුදු උදාව"
                        android:fontFamily="@font/nirmalaui"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="22dp"
                        android:textStyle="bold" />


                    <androidx.cardview.widget.CardView
                        android:id="@+id/img1"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="20dp"
                        android:backgroundTint="@color/white"
                        app:cardCornerRadius="25dp">

                        <ImageView
                            android:layout_width="160dp"
                            android:layout_height="160dp"
                            android:layout_gravity="center_horizontal"
                            android:src="@drawable/image" />


                    </androidx.cardview.widget.CardView>


                    <androidx.cardview.widget.CardView
                        android:id="@+id/txt1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"
                        android:backgroundTint="@color/white"
                        android:padding="2dp"
                        android:layout_gravity="center_horizontal"
                        app:cardCornerRadius="25dp">


                        <TextView
                            android:id="@+id/textn1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="10dp"
                            android:background="@color/time_box"
                            android:gravity="center"
                            android:textAlignment="center"
                            android:textColor="@color/black"
                            android:fontFamily="@font/nirmalaui"
                            android:textSize="20dp"
                            android:textStyle="bold" />

                    </androidx.cardview.widget.CardView>


                    <TextView

                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="30dp"
                        android:background="@drawable/nbox"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="@string/awuruduUdawa"
                        android:fontFamily="@font/nirmalaui"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="16dp"
                        android:textStyle="bold" />


                </LinearLayout>


            </FrameLayout>


            <FrameLayout
                android:id="@+id/frameTwo"
                android:layout_width="380dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="50dp"
                android:background="@drawable/list_border"
                android:padding="30dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/nbox"
                        android:padding="10dp"
                        android:text="පුණ්‍ය කාලය"
                        android:fontFamily="@font/nirmalaui"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="22dp"
                        android:textStyle="bold" />


                    <androidx.cardview.widget.CardView
                        android:layout_width="180dp"
                        android:layout_height="140dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="30dp"
                        app:cardCornerRadius="25dp">

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:src="@drawable/n2" />


                    </androidx.cardview.widget.CardView>


                    <androidx.cardview.widget.CardView
                        android:id="@+id/txt2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"
                        android:layout_gravity="center_horizontal"
                        android:backgroundTint="@color/white"
                        android:padding="2dp"
                        app:cardCornerRadius="25dp">

                        <TextView
                            android:id="@+id/textn2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="10dp"
                            android:background="@color/time_box"
                            android:gravity="center"
                            android:textAlignment="center"
                            android:fontFamily="@font/nirmalaui"
                            android:textColor="@color/black"
                            android:textSize="20dp"
                            android:textStyle="bold"/>

                    </androidx.cardview.widget.CardView>


                    <TextView

                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/nbox"
                        android:padding="15dp"
                        android:layout_marginTop="30dp"
                        android:fontFamily="@font/nirmalaui"
                        android:text="@string/punyaKala"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="16dp"
                        android:textStyle="bold" />


                </LinearLayout>
            </FrameLayout>


            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="50dp"
                android:background="@drawable/list_border"
                android:padding="30dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/nbox"
                        android:padding="10dp"
                        android:fontFamily="@font/nirmalaui"
                        android:text="ලිප ගිනි මෙලවීම හා ආහාර පිසීම"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="22dp"
                        android:textStyle="bold" />


                    <androidx.cardview.widget.CardView
                        android:layout_width="200dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="30dp"
                        android:backgroundTint="@color/white"
                        app:cardCornerRadius="25dp">

                        <ImageView
                            android:layout_width="200dp"
                            android:layout_height="match_parent"
                            android:layout_gravity="center_horizontal"
                            android:src="@drawable/n3" />


                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/txt3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"
                        android:layout_gravity="center_horizontal"
                        android:backgroundTint="@color/white"
                        android:padding="2dp"
                        app:cardCornerRadius="25dp">

                        <TextView
                            android:id="@+id/textn3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@color/time_box"
                            android:textAlignment="center"
                            android:padding="10dp"
                            android:fontFamily="@font/nirmalaui"
                            android:textColor="@color/black"
                            android:textSize="20dp"
                            android:textStyle="bold"/>

                    </androidx.cardview.widget.CardView>


                    <TextView

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/nbox"
                        android:padding="15dp"
                        android:layout_marginTop="30dp"
                        android:fontFamily="@font/nirmalaui"
                        android:text="@string/lipaginiMelaweema"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="16dp"
                        android:textStyle="bold"/>

                </LinearLayout>


            </FrameLayout>


            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="50dp"
                android:background="@drawable/list_border"
                android:padding="30dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/nbox"
                        android:padding="10dp"
                        android:fontFamily="@font/nirmalaui"
                        android:text="වැඩ ඇල්ලීම , ගණුදෙනු කිරීම හා ආහාර අනුභවය"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="22dp"
                        android:textStyle="bold" />


                    <androidx.cardview.widget.CardView
                        android:layout_width="160dp"
                        android:layout_height="150dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="30dp"
                        app:cardCornerRadius="25dp">

                        <ImageView
                            android:layout_width="250dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:src="@drawable/n4" />


                    </androidx.cardview.widget.CardView>


                    <androidx.cardview.widget.CardView
                        android:id="@+id/txt4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"
                        android:layout_gravity="center_horizontal"
                        android:backgroundTint="@color/white"
                        android:padding="2dp"
                        app:cardCornerRadius="25dp">

                        <TextView
                            android:id="@+id/textn4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@color/time_box"
                            android:textAlignment="center"
                            android:textColor="@color/black"
                            android:fontFamily="@font/nirmalaui"
                            android:textSize="20dp"
                            android:padding="10dp"
                            android:textStyle="bold" />

                    </androidx.cardview.widget.CardView>


                    <TextView

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/nbox"
                        android:layout_marginTop="30dp"
                        android:padding="15dp"
                        android:fontFamily="@font/nirmalaui"
                        android:text="@string/wadaAllima"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="16dp"
                        android:textStyle="bold" />

                </LinearLayout>


            </FrameLayout>


            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="50dp"
                android:background="@drawable/list_border"
                android:padding="30dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/nbox"
                        android:padding="10dp"
                        android:text="හිසතෙල් ගෑම"
                        android:fontFamily="@font/nirmalaui"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="22dp"
                        android:textStyle="bold" />


                    <androidx.cardview.widget.CardView
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="30dp"
                        android:backgroundTint="@color/white"
                        app:cardCornerRadius="25dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:src="@drawable/n5" />


                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/txt5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"
                        android:layout_gravity="center_horizontal"
                        android:backgroundTint="@color/white"
                        android:padding="2dp"
                        app:cardCornerRadius="25dp">

                        <TextView
                            android:id="@+id/textn5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@color/time_box"
                            android:textAlignment="center"
                            android:fontFamily="@font/nirmalaui"
                            android:textColor="@color/black"
                            android:textSize="20dp"
                            android:padding="10dp"
                            android:textStyle="bold"/>

                    </androidx.cardview.widget.CardView>


                    <TextView

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/nbox"
                        android:padding="15dp"
                        android:layout_marginTop="30dp"
                        android:fontFamily="@font/nirmalaui"
                        android:text="@string/hisathelGama"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="16dp"
                        android:textStyle="bold" />
                </LinearLayout>

            </FrameLayout>


            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="50dp"
                android:layout_marginBottom="70dp"
                android:background="@drawable/list_border"
                android:padding="30dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    tools:ignore="UselessParent">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="75dp"
                        android:layout_marginTop="10dp"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/nbox"
                        android:padding="10dp"
                        android:fontFamily="@font/nirmalaui"
                        android:text="රැකී රක්ෂා සඳහා පිටත්ව යාම"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="22dp"
                        android:textStyle="bold" />


                    <androidx.cardview.widget.CardView
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="30dp"
                        android:backgroundTint="@color/white"
                        app:cardCornerRadius="25dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:src="@drawable/n6" />


                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/txt6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"
                        android:layout_gravity="center_horizontal"
                        android:backgroundTint="@color/white"
                        android:padding="2dp"
                        app:cardCornerRadius="25dp">

                        <TextView
                            android:id="@+id/textn6"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@color/time_box"
                            android:padding="10dp"
                            android:textAlignment="center"
                            android:fontFamily="@font/nirmalaui"
                            android:textColor="@color/black"
                            android:textSize="20dp"
                            android:textStyle="bold" />


                    </androidx.cardview.widget.CardView>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/nbox"
                        android:layout_marginTop="30dp"
                        android:text="@string/job"
                        android:padding="10dp"
                        android:fontFamily="@font/nirmalaui"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="16dp"
                        android:textStyle="bold" />

                </LinearLayout>

            </FrameLayout>


        </LinearLayout>

    </ScrollView>

    <com.google.android.gms.ads.AdView
        android:id="@+id/adView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        ads:adSize="BANNER"
        ads:adUnitId="ca-app-pub-9783849108384584/9474894050"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="MissingConstraints" />

    <com.google.android.gms.ads.AdView
        android:id="@+id/adView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        ads:adSize="BANNER"
        ads:adUnitId="ca-app-pub-9783849108384584/9474894050"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.505"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.145"
        tools:ignore="MissingConstraints" />

</androidx.constraintlayout.widget.ConstraintLayout>